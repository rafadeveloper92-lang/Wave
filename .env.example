# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project.
VITE_SUPABASE_URL="https://hhgecmtljovgoqbcqleb.supabase.co"

# SUPABASE_ANON_KEY: The anonymous key for your Supabase project.
VITE_SUPABASE_ANON_KEY="sb_publishable_KR3obEpqz9WJZXWwUVS5xw_iq_rVUAy"

# Optional TURN (comma-separated URLs) for WebRTC when STUN alone is not enough (NATs restritivos).
# VITE_TURN_URLS="turn:your.turn.server:3478"
# VITE_TURN_USERNAME="user"
# VITE_TURN_CREDENTIAL="pass"

# GitHub Pages (site de projeto): o workflow define VITE_BASE_PATH=/nome-do-repo/ automaticamente.
# Para pré-visualizar localmente com o mesmo caminho: VITE_BASE_PATH=/Wave/ npm run build && npm run preview

# Mensagens de voz: no Supabase SQL Editor executar supabase/migrations/002_voice_messages.sql
# (e 001_chat_messages_base.sql só se ainda não existir chat_messages). Bucket público: chat-voice.
# Imagens/vídeos no chat: supabase/migrations/003_chat_media.sql — bucket chat-media (25 MB, vídeo até 120 s).
# Novo chat / lista de contactos: supabase/migrations/004_profiles_directory.sql (SELECT em profiles para autenticados).
# Localização no chat: supabase/migrations/005_chat_location.sql (message_type location + política INSERT).
# Presença + leitura: supabase/migrations/006_chat_presence_read.sql (last_seen_at, read_at, RLS update).

# Android (GitHub Actions): workflow build-android.yml — APK em Releases (prerelease) + artifact.
# Repo → Releases: ficheiro wave-android-debug.apk. Para Play Store, build release assinada.
